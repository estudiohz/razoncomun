# bot/.env.example
# Copiar a .env en local, o pegar como variables de entorno del servicio en Dokploy.

# --- PENDIENTE DE SERGIO: aplicación creada en el Portal de Desarrolladores de
# Discord (discord.com/developers/applications) -> Bot -> Reset Token. ---
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Servidor (guild) de Razón Común -- se usa para registrar /opina como comando
# de servidor (instantáneo) en vez de global (tarda ~1h en propagarse).
DISCORD_GUILD_ID=

# --- rc-brain-service (mismo stack de Dokploy o URL pública) ---
BRAIN_SERVICE_URL=http://brain-service:8787
BRAIN_INTERNAL_TOKEN=

# Canal(es) donde el bot responde a menciones con el corpus INTERNO (equipo).
# Si se deja vacío, responde a menciones en cualquier canal donde tenga permiso.
DISCORD_TEAM_CHANNEL_IDS=
