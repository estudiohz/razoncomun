# infra/.env.example
# Plantilla de variables de entorno para infra/docker-compose.supabase.yml y
# infra/docker-compose.ollama.yml.
#
# ⚠️ CERO POR DEFECTO: cada valor marcado [SECRETO] debe regenerarse. Los
# valores de ejemplo de la documentación oficial de Supabase están en TODOS
# los escáneres de internet (revision-seguridad.md, hallazgo C3) — usarlos
# tal cual equivale a dejar la puerta abierta.
#
# Cómo usar:
#   1. cp infra/.env.example infra/.env      (infra/.env NUNCA se commitea — ver .gitignore)
#   2. Rellenar cada [SECRETO] con el comando sugerido en su comentario
#   3. En Dokploy: pegar el contenido de infra/.env en la pestaña "Environment"
#      del servicio Compose "rc-supabase" (Dokploy no lee infra/.env del repo
#      directamente salvo que así se configure; lo normal es pegarlo en su UI)
#
# Fuera de alcance de este archivo (no tocar aquí): secretos de apps/web
# (STRIPE_*, GOOGLE_OAUTH_*, CLAUDE_API_KEY, DISCORD_BOT_TOKEN, WISE_API_TOKEN…)
# — esos viven en la config de Dokploy del servicio "rc-webapp", los define su
# agente dueño (rc-03/rc-07/rc-08/rc-09), NUNCA en infra/.

############################################
# 1. Postgres
############################################

# [SECRETO] Solo letras y números (evita problemas de URL-encoding en las
# cadenas de conexión). Generar con: openssl rand -hex 24
POSTGRES_PASSWORD=

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############################################
# 2. Claves JWT / API de Supabase
############################################

# [SECRETO] Al menos 32 caracteres. Generar con: openssl rand -base64 48
JWT_SECRET=

# [SECRETO] ANON_KEY y SERVICE_ROLE_KEY son JWT firmados con JWT_SECRET.
# Generarlos con el script oficial de Supabase (NO escribirlos a mano):
#   git clone --depth 1 https://github.com/supabase/supabase
#   cd supabase/docker && cp .env.example .env   # pegar aquí el JWT_SECRET ya generado
#   sh utils/generate-keys.sh                     # imprime ANON_KEY y SERVICE_ROLE_KEY
# ANON_KEY: se puede exponer en cliente (rol "anon", RLS manda).
ANON_KEY=
# SERVICE_ROLE_KEY: NUNCA en cliente ni en el repo. Solo server-side
# (Next.js server components/route handlers, n8n). Bypassa RLS.
SERVICE_ROLE_KEY=

# Claves opacas nuevas (opcional en esta versión de Supabase; dejar vacío si
# no se van a usar todavía — el stack funciona solo con ANON/SERVICE_ROLE_KEY
# JWT de arriba). Generar junto con lo anterior via utils/add-new-auth-keys.sh
# si se quiere adoptar el esquema de claves opacas más adelante.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

############################################
# 3. Panel (Studio vía Kong basic-auth)
############################################

DASHBOARD_USERNAME=rc_admin
# [SECRETO] Debe contener letras (no solo números). Generar con:
#   openssl rand -base64 18
DASHBOARD_PASSWORD=

############################################
# 4. Claves internas de cifrado
############################################

# [SECRETO] Realtime/Supavisor. Mínimo 64 caracteres. Generar con:
#   openssl rand -base64 48
SECRET_KEY_BASE=

# [SECRETO] Cifra campos sensibles del esquema _realtime. EXACTAMENTE 16
# caracteres. Generar con: openssl rand -hex 8
REALTIME_DB_ENC_KEY=

# [SECRETO] Cifra la cadena de conexión que usa Studio contra postgres-meta.
# Mínimo 32 caracteres. Generar con: openssl rand -base64 24
PG_META_CRYPTO_KEY=

############################################
# 5. URLs públicas (ajustar a los dominios reales una vez asignados en Dokploy)
############################################

# URL pública única del gateway Kong (sirve tanto Studio como las APIs REST/
# Auth/Storage/Realtime bajo el mismo dominio — ver GUIA-DOKPLOY.md §4 sobre
# por qué NO se separan studio.* y api.* en dos backends distintos).
SUPABASE_PUBLIC_URL=https://api.razoncomun.com

# URL externa completa del servicio Auth (se usa para construir los enlaces
# de los correos de verificación/recuperación y el callback de OAuth).
API_EXTERNAL_URL=https://api.razoncomun.com/auth/v1

# Site URL de la webapp — a donde GoTrue redirige tras verificar/confirmar.
SITE_URL=https://www.razoncomun.com
# URLs adicionales permitidas como redirect_to (coma-separadas), p.ej. staging:
ADDITIONAL_REDIRECT_URLS=https://staging.razoncomun.com

############################################
# 6. Auth — comportamiento
############################################

JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

# Rate limiting de GoTrue (C3 revision-seguridad.md) — punto de partida,
# rc-03-auth los ajusta con datos reales de uso.
GOTRUE_RATE_LIMIT_EMAIL_SENT=3
GOTRUE_RATE_LIMIT_SIGN_IN_SIGN_UPS=30
GOTRUE_RATE_LIMIT_TOKEN_REFRESH=150
GOTRUE_RATE_LIMIT_VERIFY=30

############################################
# 7. SMTP transaccional (C3 — sin esto no hay reset de contraseña ni
# verificación de email). Brevo (300/día gratis) o Resend (3k/mes gratis).
# Configurar SPF/DKIM en el dominio para no caer en spam.
############################################

SMTP_ADMIN_EMAIL=hola@razoncomun.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# [SECRETO] Contraseña/API key SMTP del proveedor elegido.
SMTP_PASS=
SMTP_SENDER_NAME=Razón Común

############################################
# 8. Storage
############################################

STORAGE_FILE_SIZE_LIMIT=52428800
GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=rc-supabase
REGION=stub

# [SECRETO] Credenciales del endpoint S3-protocol interno de Storage (no es
# S3 real; es el backend "file" hablando protocolo S3 para clientes que lo
# esperen). Generar con:
#   openssl rand -hex 16   ->  S3_PROTOCOL_ACCESS_KEY_ID
#   openssl rand -hex 32   ->  S3_PROTOCOL_ACCESS_KEY_SECRET
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############################################
# 9. API / PostgREST / Kong / imgproxy
############################################

PGRST_DB_SCHEMAS=public,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

IMGPROXY_AUTO_WEBP=true

############################################
# 10. Red de Dokploy (para exponer dominios sin publicar puertos a internet)
############################################

# Nombre de la red Docker externa que usa el Traefik de Dokploy. Verificar en
# el VPS con `docker network ls` (suele ser "dokploy-network") y corregir si
# difiere antes de desplegar.
DOKPLOY_TRAEFIK_NETWORK=dokploy-network

############################################
# 11. Studio — organización por defecto
############################################

STUDIO_DEFAULT_ORGANIZATION=Razón Común
STUDIO_DEFAULT_PROJECT=Razón Común

############################################
# 12. Backups cifrados (C4 revision-seguridad.md)
# Usadas por infra/backup/backup-pg-encrypted.sh y restore-pg-encrypted.sh.
# Este bloque lo lee el script en el HOST del VPS (no dentro de un contenedor),
# vía `source infra/.env` desde cron — ver GUIA-DOKPLOY.md §7.
############################################

# Nombre del contenedor de Postgres a volcar (coincide con container_name
# de infra/docker-compose.supabase.yml).
BACKUP_DB_CONTAINER=rc-supabase-db

# Directorio en el HOST (fuera del árbol git) donde se guardan los .age.
# NUNCA dentro del checkout del repo.
BACKUP_DIR=/opt/rc-backups

# [SECRETO — pero es una clave PÚBLICA de age, no un secreto en sí mismo;
# aun así no la pongas en el repo, vive aquí para que el cron la lea]
# Clave pública age del par de claves. La clave PRIVADA correspondiente NO
# vive en el VPS: Sergio la guarda offline (gestor de contraseñas / USB
# cifrado) — si el VPS se ve comprometido, los backups cifrados siguen
# siendo ilegibles para el atacante. Generar el par con:
#   age-keygen -o rc-backup-key.txt
#   (el fichero contiene "# public key: age1..." y la clave privada AGE-SECRET-KEY-1...)
AGE_RECIPIENT_PUBLIC_KEY=age1...

# Retención: diarios y mensuales (revision-seguridad.md C4: 30d + 12m).
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_MONTHLY=12
