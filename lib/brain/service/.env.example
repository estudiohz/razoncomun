# lib/brain/service/.env.example
# Copiar a .env en local, o pegar como variables de entorno del servicio en Dokploy.

# --- Postgres vía el endpoint HTTPS de pg-meta (mismo patrón que rc-brain-ingest) ---
SUPABASE_PUBLIC_URL=https://dev-api.razoncomun.com
SERVICE_ROLE_KEY=

# --- Ollama (embeddings de la consulta del usuario, tiempo real) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=bge-m3
EMBEDDINGS_PROVIDER=ollama
# RC_BRAIN_TEST_RUN=1 es la ÚNICA forma de permitir EMBEDDINGS_PROVIDER=mock (ver config.mjs).

# --- Anthropic (generación del chat + clasificación de Opina -- NUNCA embeddings) ---
# FALLBACK de entorno: se usa solo si no hay AI_CREDENTIALS_MASTER_KEY o no hay
# ninguna fila activa en ai_provider_credentials (ver bloque D-016 abajo). Sin
# esto Y sin un proveedor activo en la BD, /chat y /chat-team siguen recuperando
# y citando fuentes pero devuelven 503 en vez de una respuesta redactada;
# /opina/turn y /classify-opinion no pueden clasificar.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Capa multiproveedor (D-016): elegir Anthropic/OpenAI/Google desde el panel ---
# Clave maestra para descifrar la credencial activa guardada en
# ai_provider_credentials (pgcrypto). NUNCA se guarda en la base de datos --
# genera un secreto largo y aleatorio (openssl rand -hex 32) y pégalo aquí Y en
# el panel admin cuando actives el primer proveedor desde ahí. Sin esta clave,
# el servicio ignora la tabla y usa siempre el fallback ANTHROPIC_API_KEY de
# arriba (fail-soft, no fail-closed).
AI_CREDENTIALS_MASTER_KEY=
# Cada cuánto se relee la credencial activa de la BD (ms). Un cambio de
# proveedor desde el panel surte efecto en el chat/Opina dentro de este plazo,
# sin reiniciar el contenedor.
AI_CREDENTIALS_CACHE_TTL_MS=20000
# Cada cuánto el vigilante de proveedor (providerWatcher.mjs) comprueba si
# hubo un cambio y, si lo hubo, corre la suite de neutralidad automáticamente.
AI_PROVIDER_WATCH_INTERVAL_MS=20000
# Umbral mínimo (%) de pares equivalentes en la suite de neutralidad para
# aceptar un cambio de proveedor. Por debajo de esto, se revierte solo
# (ai_credentials_revert()) sin intervención humana.
AI_NEUTRALITY_MIN_PCT=95

# --- Umbral de "fuera de corpus" (calibrado en Ola 1, ver controlQuestions.mjs) ---
OUT_OF_CORPUS_THRESHOLD=0.55
RETRIEVAL_LIMIT=5

# --- Token compartido para /chat-team, /classify-opinion, /neutrality-suite/run.
# PENDIENTE DE SERGIO: generar un secreto aleatorio largo y pegarlo aquí Y en la
# config del bot de Discord / n8n. Sin esto, esas rutas devuelven 501 (fail-closed).
BRAIN_INTERNAL_TOKEN=

# --- Secreto servidor-a-servidor para POST /admin/ingest (botón "indexar
# ahora" del panel admin -- reindexa brain_entries bajo demanda). DISTINTO de
# BRAIN_INTERNAL_TOKEN a propósito: dispara trabajo con coste real
# (embeddings), nunca debe poder invocarse sin este secreto. PENDIENTE DE
# SERGIO: generar un secreto aleatorio largo (openssl rand -hex 32) y pegarlo
# aquí Y en la config del panel admin (rc-09-admin). Sin esto, /admin/ingest
# devuelve 401 siempre (fail-closed, nunca 200 "vacío").
INGEST_TRIGGER_SECRET=

# --- Chunking / lote de inserción / concurrencia de embeddings para
# /admin/ingest (ingestWiki.mjs). Mismos valores por defecto que
# lib/brain/ingest/.env.example -- no cambiar aquí sin cambiar también allí,
# o el mismo brain_entries producirá chunks distintos según qué camino lo
# reindexe. ---
CHUNK_TARGET_CHARS=1100
CHUNK_OVERLAP_CHARS=150
INSERT_BATCH_SIZE=10
EMBED_CONCURRENCY=4

# --- Sal para el hash de IP en el log de auditoría (RGPD: no guardamos IP en claro) ---
BRAIN_IP_HASH_SALT=

# --- Rate limit (I4, revision-seguridad.md) ---
RATE_LIMIT_PER_IP_PER_HOUR=30
RATE_LIMIT_PER_SESSION_PER_HOUR=20

# --- CORS del widget público ---
CORS_ALLOW_ORIGIN=https://www.razoncomun.com

PORT=8787
