# lib/brain/service/.env.example
# Copiar a .env en local, o pegar como variables de entorno del servicio en Dokploy.

# --- Postgres vía el endpoint HTTPS de pg-meta (mismo patrón que rc-brain-ingest) ---
SUPABASE_PUBLIC_URL=https://dev-api.razoncomun.com
SERVICE_ROLE_KEY=

# --- Ollama (embeddings de la consulta del usuario, tiempo real) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=bge-m3
EMBEDDINGS_PROVIDER=ollama
# RC_BRAIN_TEST_RUN=1 es la ÚNICA forma de permitir EMBEDDINGS_PROVIDER=mock (ver config.mjs).

# --- Anthropic (generación del chat + clasificación de Opina -- NUNCA embeddings) ---
# PENDIENTE DE SERGIO: sin esto, /chat y /chat-team siguen recuperando y citando
# fuentes pero devuelven 503 en vez de una respuesta redactada; /opina/turn y
# /classify-opinion no pueden clasificar.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Umbral de "fuera de corpus" (calibrado en Ola 1, ver controlQuestions.mjs) ---
OUT_OF_CORPUS_THRESHOLD=0.55
RETRIEVAL_LIMIT=5

# --- Token compartido para /chat-team, /classify-opinion, /neutrality-suite/run.
# PENDIENTE DE SERGIO: generar un secreto aleatorio largo y pegarlo aquí Y en la
# config del bot de Discord / n8n. Sin esto, esas rutas devuelven 501 (fail-closed).
BRAIN_INTERNAL_TOKEN=

# --- Sal para el hash de IP en el log de auditoría (RGPD: no guardamos IP en claro) ---
BRAIN_IP_HASH_SALT=

# --- Rate limit (I4, revision-seguridad.md) ---
RATE_LIMIT_PER_IP_PER_HOUR=30
RATE_LIMIT_PER_SESSION_PER_HOUR=20

# --- CORS del widget público ---
CORS_ALLOW_ORIGIN=https://www.razoncomun.com

PORT=8787
