# lib/brain/ingest/.env.example
#
# Copiar a .env para pruebas locales (nunca commitear .env -- ver .gitignore
# raíz). En Dokploy, pegar estas mismas variables en la pestaña "Environment"
# del servicio del job (docker-compose.brain-ingest.yml).

############################################
# Postgres, vía el endpoint HTTPS de pg-meta
############################################

# URL pública de Kong (misma que usa el resto del stack). En desarrollo:
# https://dev-api.razoncomun.com — en producción: https://api.razoncomun.com
SUPABASE_PUBLIC_URL=https://dev-api.razoncomun.com

# [SECRETO] service_role -- bypassa RLS, brain_documents solo es accesible
# con esta clave (ver supabase/migrations/0012_brain.sql). Vive en la config
# de Dokploy del servicio "rc-supabase" (D-004) -- copiar de ahí, jamás del
# repo ni de ningún commit.
SERVICE_ROLE_KEY=

############################################
# Ollama (embeddings bge-m3)
############################################

# Solo alcanzable desde dentro de la red rc-ollama-internal del VPS -- ver
# README "Redes: cómo llega este job a Ollama".
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=bge-m3

# 'ollama' en producción SIEMPRE. 'mock' solo en local con RC_BRAIN_TEST_RUN=1
# (ver src/config.mjs) -- genera vectores falsos deterministas para probar la
# mecánica del pipeline sin acceso a Ollama, nunca para poblar corpus real.
EMBEDDINGS_PROVIDER=ollama
RC_BRAIN_TEST_RUN=0

############################################
# Corpus de documentos (bind mount de solo lectura, ver README)
############################################

CORPUS_PUBLIC_DIR=/corpus/public
CORPUS_INTERNAL_DIR=/corpus/internal

############################################
# Chunking / lotes
############################################

CHUNK_TARGET_CHARS=1100
CHUNK_OVERLAP_CHARS=150
INSERT_BATCH_SIZE=10
EMBED_CONCURRENCY=4

############################################
# Solo para docker-compose.brain-ingest.yml (variables de despliegue, no las
# lee el script Node -- las usa Docker Compose para el bind mount y la red)
############################################

# Directorio en el HOST del VPS donde vive el corpus de documentos (ver
# README "Corpus de documentos: por qué NO vive en este repo público").
# Poblado fuera de git, vía rsync/scp desde el repo privado de documentación.
RC_CORPUS_HOST_DIR=/opt/rc-corpus

# Nombre real de la red Docker de Ollama -- confirmar con
# `docker network ls | grep ollama` antes del primer despliegue (ver README
# "Redes: cómo llega este job a Ollama"). Deja el default si coincide.
OLLAMA_INTERNAL_NETWORK=rc-ollama_rc-ollama-internal
